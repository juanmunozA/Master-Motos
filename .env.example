NODE_ENV=development
HOST=127.0.0.1
PORT=8182

# Usa postgres para guardar en PostgreSQL.
# Usa file para guardar en backend/data/master-data.csv.
# Usa auto para PostgreSQL si DATABASE_URL existe; si no, CSV.
STORAGE_DRIVER=postgres

# Ejemplo local:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/master_motos
DATABASE_URL=

# Activa SSL si tu proveedor de PostgreSQL lo exige.
PGSSL=false

# Login simple (un solo usuario, identificado por cedula). Deja ambos vacios para desactivar el login.
# Genera el hash con: npm run hash-password -- "tu-contrasena"
AUTH_USERNAME=
AUTH_PASSWORD_HASH=
